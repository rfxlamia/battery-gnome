[Unit]
Description=Battery Core — Anthropic usage monitor background service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/env node %h/.local/share/battery/core/dist/main.js --loop
Restart=on-failure
RestartSec=10
Environment=HOME=%h

[Install]
WantedBy=default.target
